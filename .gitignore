# ====================================
# UPEX Project Starter - .gitignore
# ====================================

# Dependencies
node_modules/

# ===== Build Artifacts =====
dist/
build/
.next/
*.tsbuildinfo
next-env.d.ts

# ===== Playwright Test Artifacts =====
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# ===== Auth Storage (Session State) =====
/.auth/

# ===== Allure Reports =====
/allure-results/
/allure-report/

# ===== Custom Reports =====
/reports/
*.json.bak

# ===== Debug Logs =====
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== Environment =====
.env
.env.local
.env.*.local
.env.sentry-build-plugin

# ===== IDE & Editor =====
.idea/
*.swp
*.swo
*.code-workspace

# ===== OS Files =====
.DS_Store
Thumbs.db

# ===== Vercel =====
.vercel

# ===== AI CLI Tools & Configs =====
.serena
.gemini/
.claude/
.playwright-mcp
.backups/
.context/mcp/outputs

# ===== MCP Configuration (contain secrets - DO NOT COMMIT) =====
.mcp.json
.mcp.catalog.json
*.catalog.json
.mcpservers.json
opencode.json
dbhub.toml
